#!/usr/bin/env python3
"""dic — "say!" (Latin imperative of dīcere). Thin client for dic-daemon.

Speaks via Kokoro-MLX through a daemon held warm in memory by launchd.
The daemon listens on /tmp/dic.sock and is started by
~/Library/LaunchAgents/co.lorey.dic-daemon.plist; if the socket is
missing this client falls back to spawning the daemon inline (slow path,
~5 s cold start, but always works).
"""

from __future__ import annotations

import argparse
import fcntl
import json
import os
import socket
import subprocess
import sys
import time

SOCKET_PATH = "/tmp/dic.sock"
DEFAULT_VOICE = "bf_isabella"
DAEMON_BIN = os.path.expanduser("~/.local/bin/dic-daemon")
LOCK_PATH = os.path.expanduser("~/.cache/dic.lock")
CONNECT_TIMEOUT = 30.0  # seconds; covers daemon cold start + model load
REQUEST_TIMEOUT = 3600.0  # seconds; covers long-form streaming playback


def acquire_lock() -> int:
    """Block until this process owns the dic lock, then return its fd.

    The daemon is a single Kokoro worker behind one Unix socket. Two
    clients hitting it concurrently can race — one stream gets closed
    mid-playback and the other client reads zero bytes and crashes on
    JSON-decoding the empty response. fcntl.flock(LOCK_EX) ensures only
    one client holds the daemon at a time; late callers wait their turn
    rather than getting their playback cut off. The lock is held for
    the entire request including playback, since the daemon only sends
    its final JSON ack after audio streaming completes.

    fcntl locks release automatically on fd close, including abnormal
    process exit — no stale-lock recovery needed.
    """
    os.makedirs(os.path.dirname(LOCK_PATH), exist_ok=True)
    fd = os.open(LOCK_PATH, os.O_RDWR | os.O_CREAT, 0o644)
    fcntl.flock(fd, fcntl.LOCK_EX)
    return fd


def release_lock(fd: int) -> None:
    try:
        fcntl.flock(fd, fcntl.LOCK_UN)
    finally:
        os.close(fd)


def connect(timeout: float = CONNECT_TIMEOUT) -> socket.socket:
    deadline = time.monotonic() + timeout
    last_err: Exception | None = None
    while time.monotonic() < deadline:
        try:
            s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
            s.settimeout(REQUEST_TIMEOUT)
            s.connect(SOCKET_PATH)
            return s
        except (FileNotFoundError, ConnectionRefusedError) as e:
            last_err = e
            time.sleep(0.2)
    raise RuntimeError(f"could not connect to {SOCKET_PATH}: {last_err}")


def ensure_daemon() -> None:
    """If socket is missing, launch the daemon in the background."""
    if os.path.exists(SOCKET_PATH):
        return
    try:
        subprocess.Popen(
            [DAEMON_BIN],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
    except FileNotFoundError:
        sys.exit(f"dic: daemon binary not found at {DAEMON_BIN}")


def request(req: dict) -> dict:
    ensure_daemon()
    lock_fd = acquire_lock()
    try:
        s = connect()
        try:
            s.sendall((json.dumps(req) + "\n").encode("utf-8"))
            buf = b""
            while b"\n" not in buf:
                chunk = s.recv(65536)
                if not chunk:
                    break
                buf += chunk
            line = buf.split(b"\n", 1)[0]
            if not line:
                raise RuntimeError(
                    "dic-daemon closed the connection without responding; "
                    "the worker may have crashed mid-request"
                )
            return json.loads(line.decode("utf-8"))
        finally:
            s.close()
    finally:
        release_lock(lock_fd)


def read_text(arg: str | None) -> str:
    if arg:
        return arg
    if not sys.stdin.isatty():
        return sys.stdin.read()
    return ""


def main() -> int:
    p = argparse.ArgumentParser(
        prog="dic",
        description="Speak text aloud via the dic-daemon Kokoro-MLX TTS service.",
    )
    p.add_argument("text", nargs="?", help="Text to speak. If omitted, reads stdin.")
    p.add_argument("-v", "--voice", default=DEFAULT_VOICE,
                   help=f"Voice (default: {DEFAULT_VOICE})")
    p.add_argument("-s", "--speed", type=float, default=None,
                   help="Speech speed (default: 1.0)")
    p.add_argument("-o", "--output", default=None,
                   help="Save audio to this WAV file instead of playing.")
    p.add_argument("-f", "--format", default=None,
                   help="Audio format. Only 'wav' is supported.")
    p.add_argument("-l", "--lang", default=None, help="Language code.")
    p.add_argument("--voices", action="store_true",
                   help="List available voices and exit.")
    p.add_argument("--reset", action="store_true",
                   help="Tell the daemon to drop its loaded TTS instance "
                        "(re-initializes the audio device on the next call). "
                        "Use to recover from silent audio without restarting "
                        "the daemon.")
    p.add_argument("--verbose", action="store_true",
                   help="Show progress and daemon responses on stderr.")
    args = p.parse_args()

    if args.format and args.format.lower() != "wav":
        print(f"dic: format '{args.format}' unsupported; using wav", file=sys.stderr)

    if args.reset:
        resp = request({"action": "reset"})
        if not resp.get("ok"):
            sys.exit(f"dic: {resp.get('error')}")
        return 0

    if args.voices:
        resp = request({"action": "list_voices"})
        if not resp.get("ok"):
            sys.exit(f"dic: {resp.get('error')}")
        for v in resp.get("voices", []):
            print(v)
        return 0

    text = read_text(args.text)
    if not text.strip():
        p.print_help(sys.stderr)
        return 1

    req: dict = {"text": text, "voice": args.voice}
    if args.speed is not None:
        req["speed"] = args.speed
    if args.lang:
        req["lang"] = args.lang

    if args.output:
        req["action"] = "save"
        req["output"] = os.path.abspath(args.output)
    else:
        req["action"] = "speak"

    resp = request(req)
    if not resp.get("ok"):
        sys.exit(f"dic: {resp.get('error')}")
    if args.verbose:
        print(json.dumps(resp), file=sys.stderr)
    return 0


if __name__ == "__main__":
    sys.exit(main())
