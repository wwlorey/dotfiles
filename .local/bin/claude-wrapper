#!/bin/bash

set -euo pipefail  # Exit on error, undefined vars, pipe failures

args=()
if [[ -z "${PROMPT_FILES:-}" ]]; then
  echo "Warning: PROMPT_FILES not set" >&2
else
  IFS=':' read -ra _prompt_files <<< "$PROMPT_FILES"

  studies=()
  for f in "${_prompt_files[@]}"; do
    expanded="${f/\$HOME/$HOME}"
    expanded="${expanded/#~/$HOME}"
    if [[ -f "$expanded" ]]; then
      studies+=("study @$expanded")
    else
      echo "Warning: $expanded not found" >&2
    fi
  done

  if [[ ${#studies[@]} -gt 0 ]]; then
    instruction=$(IFS='; '; echo "${studies[*]}")
    args+=(--append-system-prompt "$instruction")
  fi
fi

exec claude-wrapper-secret "${args[@]}" "$@"
