#!/usr/bin/env bash
set -euo pipefail

MUTE_FILE="$HOME/.local/share/dic/mute"

mute() {
    mkdir -p "$(dirname "$MUTE_FILE")"
    touch "$MUTE_FILE"
    echo "dic muted"
}

unmute() {
    rm -f "$MUTE_FILE"
    echo "dic unmuted"
}

case "${1:-toggle}" in
    on)     mute ;;
    off)    unmute ;;
    toggle) if [[ -f "$MUTE_FILE" ]]; then unmute; else mute; fi ;;
    *)      echo "Usage: dic-mute [on|off|toggle]" >&2; exit 2 ;;
esac
