set shell zsh

cmd v $nvim "$1"

# Periodically check for directory updates
set period 1

# Keep tmux @shell_cwd in sync so tmux bindings (e.g. prefix-o) open the
# directory currently selected in lf, not the one from when lf launched.
cmd on-cd &{{
  if [ -n "$TMUX" ]; then
    tmux set-option -p @shell_cwd "$PWD"
  fi
}}
on-cd

set hiddenfiles ".*:*.aux:*.log:*.bbl:*.bcf:*.blg:*.run.xml"

set mouse true

set previewer ~/.config/lf/scope

cmd openHandler ${{
  case $(file --mime-type $f -b) in
    text/*|application/json) $EDITOR $fx;;
    *) open $fx;;
  esac
}}
map <enter> openHandler $f

cmd delete ${{
  printf "%s\n  " "$fx"
  printf "Delete? [y/n] "
  read ans
  if [ $ans = "y" ]; then
    printf '%s\n' $fx | while IFS= read -r fileName; do
      trash "$fileName"
    done
  fi
}}
map D delete

cmd m %mkdir -p "$@"

cmd moveto ${{
	destFile="$HOME/$(cd $HOME && fzf)"
  destPath="$(dirname $destFile)"
	for x in "$fx"; do
    echo "$x"
    echo "$destPath"
		eval mv -iv \"$x\" \"$destPath\"
	done
}}
map m moveto $f

cmd yank-name &basename "$f" | tr -d '\n' | pbcopy
map Y yank-name

map A rename      # End of filename
map C push A<c-u> # New filename
map I push A<c-a> # Beginning of filename

