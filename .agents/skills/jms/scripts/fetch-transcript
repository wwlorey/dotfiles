#!/usr/bin/env bash
# fetch-transcript <video-id|url> — print a YouTube video's cleaned auto-caption
# transcript to stdout. Exits non-zero with empty stdout if no captions exist
# yet. Shared by jms-digest and the email-chat poller.
set -euo pipefail

arg="${1:-}"
[ -n "$arg" ] || { echo "usage: fetch-transcript <video-id|url>" >&2; exit 2; }
case "$arg" in
  http*://*) url="$arg" ;;
  *) url="https://www.youtube.com/watch?v=$arg" ;;
esac

command -v yt-dlp >/dev/null 2>&1 || { echo "fetch-transcript: yt-dlp not found" >&2; exit 1; }

work="$(mktemp -d "${TMPDIR:-/tmp}/jms-transcript.XXXXXX")"
trap 'rm -rf "$work"' EXIT

yt-dlp --no-warnings --skip-download \
  --write-auto-subs --write-subs --sub-langs "en.*" --sub-format vtt \
  -o "$work/sub.%(ext)s" "$url" >/dev/null 2>&1 || true

vtt="$(find "$work" -name '*.vtt' -print -quit)"
[ -n "$vtt" ] || { echo "fetch-transcript: no captions available for $url" >&2; exit 1; }

# Strip the WEBVTT header, cue-timing lines, inline tags, and blank lines, then
# drop duplicate lines (auto-captions repeat each phrase across rolling frames).
transcript="$(
  grep -vE '^(WEBVTT|Kind:|Language:|NOTE|[0-9]{2}:[0-9]{2}:[0-9]{2}[.,][0-9]{3} -->)' "$vtt" |
    sed -E 's/<[^>]+>//g; s/^[[:space:]]+//; s/[[:space:]]+$//' |
    grep -vE '^$' |
    awk '!seen[$0]++' || true
)"

[ -n "$transcript" ] || { echo "fetch-transcript: transcript empty after cleanup" >&2; exit 1; }
printf '%s\n' "$transcript"
