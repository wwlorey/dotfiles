{
  "autoMemoryEnabled": false,
  "statusLine": {
    "type": "command",
    "command": "sh $HOME/.claude/statusline.sh"
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "excludedCommands": [
      "pnpm add*",
      "pnpm exec playwright install",
      "pnpm install*",
      "pnpm run test:e2e*",
      "node*export.js*"
    ],
    "filesystem": {
      "allowWrite": [
        "~/.cache/prek",
        "~/.cargo",
        "~/.local/share/forma",
        "~/.local/share/pensa",
        "~/.pnpm-store",
        "~/Library/Caches/ms-playwright",
        "~/.sgf",
        "/tmp",
        "/private/tmp"
      ]
    },
    "network": {
      "allowedDomains": [
        "localhost",
        "github.com",
        "*.githubusercontent.com",
        "crates.io",
        "*.crates.io",
        "registry.npmjs.org",
        "registry.yarnpkg.com"
      ],
      "allowLocalBinding": true
    }
  },
  "permissions": {
    "allow": [
      "Read(~/.cargo/*)",
      "Read(~/.sgf/*)",
      "Bash(pnpm install*)",
      "Bash(pnpm add*)",
      "Bash(pnpm run test:e2e*)"
    ],
    "deny": [
      "Read ~/.ssh/**",
      "Read ~/.gnupg/**",
      "Read ~/.aws/**",
      "Read ~/.config/gcloud/**",
      "Read ~/Library/Keychains/**",
      "Read ~/Library/Cookies/**",
      "Read ~/Library/Application Support/Google/Chrome/**",
      "Read ~/Library/Application Support/Firefox/**",
      "Read ~/Library/Application Support/Arc/**",
      "Read ~/.kube/config",
      "Read ~/.docker/config.json",
      "Read ~/.netrc",
      "Read ~/.local/bin/**",
      "Read ~/.npmrc",
      "Read ~/.cargo/credentials.toml",
      "Read ~/.pypirc",
      "Read ~/.gem/credentials",
      "Read ~/.git-credentials",
      "Read ~/.config/gh/hosts.yml",
      "Read ~/.vault-token",
      "Read ~/.terraform.d/credentials.tfrc.json",
      "Read ~/.config/op/**",
      "Read ~/.config/stripe/**",
      "Read ~/.age/**",
      "Read ~/.env",
      "Read ~/.env.*",
      "Read ~/Library/Messages/**",
      "Read ~/Library/Mail/**",
      "Read ~/Library/Calendars/**",
      "Read ~/Library/Contacts/**",
      "Read ~/Library/Safari/**",
      "Read ~/Library/Mobile Documents/**",
      "Read ~/Library/Application Support/Slack/**",
      "Read ~/Library/Application Support/Discord/**",
      "Read ~/Library/Application Support/Signal/**",
      "Read ~/Library/Application Support/Telegram/**",
      "Read ~/Library/Application Support/1Password/**",
      "Read ~/.password-store/**",
      "Read ~/.config/keybase/**",
      "Read ~/.Trash/**",

      "Grep ~/.ssh/**",
      "Grep ~/.gnupg/**",
      "Grep ~/.aws/**",
      "Grep ~/.config/gcloud/**",
      "Grep ~/Library/Keychains/**",
      "Grep ~/Library/Cookies/**",
      "Grep ~/Library/Application Support/Google/Chrome/**",
      "Grep ~/Library/Application Support/Firefox/**",
      "Grep ~/Library/Application Support/Arc/**",
      "Grep ~/.kube/config",
      "Grep ~/.docker/config.json",
      "Grep ~/.netrc",
      "Grep ~/.local/bin/**",
      "Grep ~/.npmrc",
      "Grep ~/.cargo/credentials.toml",
      "Grep ~/.pypirc",
      "Grep ~/.gem/credentials",
      "Grep ~/.git-credentials",
      "Grep ~/.config/gh/hosts.yml",
      "Grep ~/.vault-token",
      "Grep ~/.terraform.d/credentials.tfrc.json",
      "Grep ~/.config/op/**",
      "Grep ~/.config/stripe/**",
      "Grep ~/.age/**",
      "Grep ~/.env",
      "Grep ~/.env.*",
      "Grep ~/Library/Messages/**",
      "Grep ~/Library/Mail/**",
      "Grep ~/Library/Calendars/**",
      "Grep ~/Library/Contacts/**",
      "Grep ~/Library/Safari/**",
      "Grep ~/Library/Mobile Documents/**",
      "Grep ~/Library/Application Support/Slack/**",
      "Grep ~/Library/Application Support/Discord/**",
      "Grep ~/Library/Application Support/Signal/**",
      "Grep ~/Library/Application Support/Telegram/**",
      "Grep ~/Library/Application Support/1Password/**",
      "Grep ~/.password-store/**",
      "Grep ~/.config/keybase/**",
      "Grep ~/.Trash/**",

      "Glob ~/.ssh/**",
      "Glob ~/.gnupg/**",
      "Glob ~/.aws/**",
      "Glob ~/.config/gcloud/**",
      "Glob ~/Library/Keychains/**",
      "Glob ~/Library/Cookies/**",
      "Glob ~/Library/Application Support/Google/Chrome/**",
      "Glob ~/Library/Application Support/Firefox/**",
      "Glob ~/Library/Application Support/Arc/**",
      "Glob ~/.kube/**",
      "Glob ~/.local/bin/**",
      "Glob ~/.cargo/credentials.toml",
      "Glob ~/.git-credentials",
      "Glob ~/.config/gh/**",
      "Glob ~/.config/op/**",
      "Glob ~/.config/stripe/**",
      "Glob ~/.age/**",
      "Glob ~/Library/Messages/**",
      "Glob ~/Library/Mail/**",
      "Glob ~/Library/Calendars/**",
      "Glob ~/Library/Contacts/**",
      "Glob ~/Library/Safari/**",
      "Glob ~/Library/Mobile Documents/**",
      "Glob ~/Library/Application Support/Slack/**",
      "Glob ~/Library/Application Support/Discord/**",
      "Glob ~/Library/Application Support/Signal/**",
      "Glob ~/Library/Application Support/Telegram/**",
      "Glob ~/Library/Application Support/1Password/**",
      "Glob ~/.password-store/**",
      "Glob ~/.config/keybase/**",
      "Glob ~/.Trash/**",

      "Edit ~/.ssh/**",
      "Edit ~/.gnupg/**",
      "Edit ~/.aws/**",
      "Edit ~/.config/gcloud/**",
      "Edit ~/.local/bin/**",
      "Edit ~/.bashrc",
      "Edit ~/.bash_profile",
      "Edit ~/.zshrc",
      "Edit ~/.zprofile",
      "Edit ~/.profile",
      "Edit ~/.npmrc",
      "Edit ~/.cargo/credentials.toml",
      "Edit ~/.pypirc",
      "Edit ~/.gem/credentials",
      "Edit ~/.git-credentials",
      "Edit ~/.config/gh/hosts.yml",
      "Edit ~/.claude/settings.json",
      "Edit ~/.claude/hooks/**",
      "Edit ~/.vault-token",
      "Edit ~/.terraform.d/credentials.tfrc.json",
      "Edit ~/.config/op/**",
      "Edit ~/.config/stripe/**",
      "Edit ~/.age/**",
      "Edit ~/.env",
      "Edit ~/.env.*",
      "Edit ~/.Trash/**",
      "Edit /usr/local/bin/**",
      "Edit /opt/homebrew/bin/**",

      "Write ~/.ssh/**",
      "Write ~/.gnupg/**",
      "Write ~/.aws/**",
      "Write ~/.config/gcloud/**",
      "Write ~/.local/bin/**",
      "Write ~/.bashrc",
      "Write ~/.bash_profile",
      "Write ~/.zshrc",
      "Write ~/.zprofile",
      "Write ~/.profile",
      "Write ~/.npmrc",
      "Write ~/.cargo/credentials.toml",
      "Write ~/.pypirc",
      "Write ~/.gem/credentials",
      "Write ~/.git-credentials",
      "Write ~/.config/gh/hosts.yml",
      "Write ~/.claude/settings.json",
      "Write ~/.claude/hooks/**",
      "Write ~/.vault-token",
      "Write ~/.terraform.d/credentials.tfrc.json",
      "Write ~/.config/op/**",
      "Write ~/.config/stripe/**",
      "Write ~/.age/**",
      "Write ~/.env",
      "Write ~/.env.*",
      "Write ~/.Trash/**",
      "Write /usr/local/bin/**",
      "Write /opt/homebrew/bin/**",

      "Bash(security find-*)",
      "Bash(security dump-*)",
      "Bash(security export-*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p \"$TMPDIR\" 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/require-claude-wrapper.sh"
          },
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/protect-dirs.py"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Blow.aiff &>/dev/null &"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Blow.aiff &>/dev/null &"
          }
        ]
      }
    ]
  }
}
