{
  "autoMemoryEnabled": false,
  "statusLine": {
    "type": "command",
    "command": "sh $HOME/.claude/statusline.sh"
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "excludedCommands": [
      "pnpm add*",
      "pnpm exec playwright install",
      "pnpm install*",
      "pnpm run test:e2e*",
      "node*export.js*",
      "cargo*",
      "agent*",
      "*face-reading/scripts/*"
    ],
    "filesystem": {
      "allowWrite": [
        "~/.cache/prek",
        "~/.cache/uv",
        "~/.cache/face-reading",
        "~/.local/share/uv",
        "~/.cargo",
        "~/.pnpm-store",
        "~/Library/Caches/ms-playwright",
        "~/.Trash",
        "/tmp",
        "/private/tmp",
        "~/Repos/dotfiles",
        "~/Repos/hooked-on-pa/node_modules/.vite-temp"
      ]
    },
    "network": {
      "allowedDomains": [
        "localhost",
        "github.com",
        "*.githubusercontent.com",
        "crates.io",
        "*.crates.io",
        "registry.npmjs.org",
        "registry.yarnpkg.com",
        "pypi.org",
        "files.pythonhosted.org",
        "storage.googleapis.com",
        "api.instantdb.com",
        "api.openai.com"
      ],
      "allowLocalBinding": true
    }
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Read(~/.cargo/*)",
      "Bash(pnpm install*)",
      "Bash(pnpm add*)",
      "Bash(pnpm run test:e2e*)"
    ],
    "deny": [
      "Read ~/.ssh/**",
      "Read ~/.gnupg/**",
      "Read ~/.aws/**",
      "Read ~/.config/gcloud/**",
      "Read ~/Library/Keychains/**",
      "Read ~/Library/Cookies/**",
      "Read ~/Library/Application Support/Google/Chrome/**",
      "Read ~/Library/Application Support/Firefox/**",
      "Read ~/Library/Application Support/Arc/**",
      "Read ~/.kube/config",
      "Read ~/.docker/config.json",
      "Read ~/.netrc",
      "Read ~/.local/bin/**",
      "Read ~/.npmrc",
      "Read ~/.cargo/credentials.toml",
      "Read ~/.pypirc",
      "Read ~/.gem/credentials",
      "Read ~/.git-credentials",
      "Read ~/.config/gh/hosts.yml",
      "Read ~/.vault-token",
      "Read ~/.terraform.d/credentials.tfrc.json",
      "Read ~/.config/op/**",
      "Read ~/.config/stripe/**",
      "Read ~/.age/**",
      "Read ~/.env",
      "Read ~/.env.*",
      "Read ~/Library/Messages/**",
      "Read ~/Library/Mail/**",
      "Read ~/Library/Calendars/**",
      "Read ~/Library/Contacts/**",
      "Read ~/Library/Safari/**",
      "Read ~/Library/Mobile Documents/**",
      "Read ~/Library/Application Support/Slack/**",
      "Read ~/Library/Application Support/Discord/**",
      "Read ~/Library/Application Support/Signal/**",
      "Read ~/Library/Application Support/Telegram/**",
      "Read ~/Library/Application Support/1Password/**",
      "Read ~/.password-store/**",
      "Read ~/.config/keybase/**",
      "Read ~/.Trash/**",

      "Grep ~/.ssh/**",
      "Grep ~/.gnupg/**",
      "Grep ~/.aws/**",
      "Grep ~/.config/gcloud/**",
      "Grep ~/Library/Keychains/**",
      "Grep ~/Library/Cookies/**",
      "Grep ~/Library/Application Support/Google/Chrome/**",
      "Grep ~/Library/Application Support/Firefox/**",
      "Grep ~/Library/Application Support/Arc/**",
      "Grep ~/.kube/config",
      "Grep ~/.docker/config.json",
      "Grep ~/.netrc",
      "Grep ~/.local/bin/**",
      "Grep ~/.npmrc",
      "Grep ~/.cargo/credentials.toml",
      "Grep ~/.pypirc",
      "Grep ~/.gem/credentials",
      "Grep ~/.git-credentials",
      "Grep ~/.config/gh/hosts.yml",
      "Grep ~/.vault-token",
      "Grep ~/.terraform.d/credentials.tfrc.json",
      "Grep ~/.config/op/**",
      "Grep ~/.config/stripe/**",
      "Grep ~/.age/**",
      "Grep ~/.env",
      "Grep ~/.env.*",
      "Grep ~/Library/Messages/**",
      "Grep ~/Library/Mail/**",
      "Grep ~/Library/Calendars/**",
      "Grep ~/Library/Contacts/**",
      "Grep ~/Library/Safari/**",
      "Grep ~/Library/Mobile Documents/**",
      "Grep ~/Library/Application Support/Slack/**",
      "Grep ~/Library/Application Support/Discord/**",
      "Grep ~/Library/Application Support/Signal/**",
      "Grep ~/Library/Application Support/Telegram/**",
