      "Glob ~/Library/Cookies/**",
      "Glob ~/Library/Application Support/Google/Chrome/**",
      "Glob ~/Library/Application Support/Firefox/**",
      "Glob ~/Library/Application Support/Arc/**",
      "Glob ~/.kube/**",
      "Glob ~/.local/bin/**",
      "Glob ~/.cargo/credentials.toml",
      "Glob ~/.git-credentials",
      "Glob ~/.config/gh/**",
      "Glob ~/.config/op/**",
      "Glob ~/.config/stripe/**",
      "Glob ~/.age/**",
      "Glob ~/Library/Messages/**",
      "Glob ~/Library/Mail/**",
      "Glob ~/Library/Calendars/**",
      "Glob ~/Library/Contacts/**",
      "Glob ~/Library/Safari/**",
      "Glob ~/Library/Mobile Documents/**",
      "Glob ~/Library/Application Support/Slack/**",
      "Glob ~/Library/Application Support/Discord/**",
