      "Edit ~/.gnupg/**",
      "Edit ~/.aws/**",
      "Edit ~/.config/gcloud/**",
      "Edit ~/.local/bin/**",
      "Edit ~/.bashrc",
      "Edit ~/.bash_profile",
      "Edit ~/.zshrc",
      "Edit ~/.zprofile",
      "Edit ~/.profile",
      "Edit ~/.npmrc",
      "Edit ~/.cargo/credentials.toml",
      "Edit ~/.pypirc",
      "Edit ~/.gem/credentials",
      "Edit ~/.git-credentials",
      "Edit ~/.config/gh/hosts.yml",
      "Edit ~/.claude/settings.json",
      "Edit ~/.claude/hooks/**",
      "Edit ~/.vault-token",
      "Edit ~/.terraform.d/credentials.tfrc.json",
      "Edit ~/.config/op/**",
      "Edit ~/.config/stripe/**",
      "Edit ~/.age/**",
      "Edit ~/.env",
      "Edit ~/.env.*",
      "Edit ~/.Trash/**",
      "Edit /usr/local/bin/**",
      "Edit /opt/homebrew/bin/**",

      "Write ~/.ssh/**",
      "Write ~/.gnupg/**",
      "Write ~/.aws/**",
      "Write ~/.config/gcloud/**",
      "Write ~/.local/bin/**",
      "Write ~/.bashrc",
      "Write ~/.bash_profile",
      "Write ~/.zshrc",
      "Write ~/.zprofile",
      "Write ~/.profile",
      "Write ~/.npmrc",
      "Write ~/.cargo/credentials.toml",
      "Write ~/.pypirc",
      "Write ~/.gem/credentials",
      "Write ~/.git-credentials",
      "Write ~/.config/gh/hosts.yml",
      "Write ~/.claude/settings.json",
      "Write ~/.claude/hooks/**",
      "Write ~/.vault-token",
      "Write ~/.terraform.d/credentials.tfrc.json",
      "Write ~/.config/op/**",
      "Write ~/.config/stripe/**",
      "Write ~/.age/**",
      "Write ~/.env",
      "Write ~/.env.*",
      "Write ~/.Trash/**",
      "Write /usr/local/bin/**",
      "Write /opt/homebrew/bin/**",

      "Bash(security find-*)",
      "Bash(security dump-*)",
      "Bash(security export-*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p \"$TMPDIR\" 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command'); if echo \"$cmd\" | grep -qE '(^|;|&&|\\|\\|)[[:space:]]*rm[[:space:]]'; then jq -n '{hookSpecificOutput:{hookEventName:\"PreToolUse\",permissionDecision:\"deny\",permissionDecisionReason:\"Use `trash` instead of `rm` so deletions are recoverable from ~/.Trash. Example: `trash <files>`. Hook lives in ~/.claude/settings.json.\"}}'; fi"
          },
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/block-force-push.py"
          },
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/redirect-bash-to-mcp.py"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "# Keep tmux @shell_cwd in sync with Claude Code's project root so new pane splits open in the right directory. Fires on every tool call (not just Bash) so it's set before the user can open a new window. The CLAUDECODE guard in .zshrc prevents bash subshells from overwriting this.\n[ -n \"$TMUX\" ] && [ -n \"$TMUX_PANE\" ] && tmux set-option -qp -t \"$TMUX_PANE\" @shell_cwd \"$(pwd)\" 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/require-agent-script.sh"
          },
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/protect-dirs.py"
          },
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/redirect-config-edits.py"
          }
        ]
      }
    ]
  }
}
